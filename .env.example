# ─────────────────────────────────────────────
# WritOnline — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to GitHub
# ─────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────
# PlanetScale (free MySQL):
# Get from: planetscale.com → your database → Connect → Prisma
DATABASE_URL="mysql://username:password@host/writonline?ssl={"rejectUnauthorized":true}"

# Alternative — Railway (free MySQL):
# DATABASE_URL="mysql://root:password@containers-us-west-1.railway.app:PORT/railway"

# ── NEXTAUTH ──────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel, set NEXTAUTH_URL to your actual domain:
# NEXTAUTH_URL="https://writonline.in"

# ── GOOGLE OAUTH (optional — for Google login) ─
# Get from: console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── EMAIL (for magic link / password reset) ───
# Using Resend (free 3000 emails/month): resend.com
RESEND_API_KEY=""
EMAIL_FROM="noreply@writonline.in"

# ── FILE STORAGE ──────────────────────────────
# Cloudflare R2 (free 10GB):
# Get from: Cloudflare Dashboard → R2
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="writonline-docs"
CLOUDFLARE_R2_PUBLIC_URL="https://docs.writonline.in"

# ── PAYMENTS (Razorpay) ───────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── AI (Anthropic Claude for drafting) ────────
ANTHROPIC_API_KEY=""

# ── APP ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="WritOnline"
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
